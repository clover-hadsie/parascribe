# parascribe configuration (env vars). Copy to .env for local dev.
# All keys are prefixed PARASCRIBE_ when set in the environment.

# --- Model / inference ---
PARASCRIBE_MODEL_ID=istupakov/parakeet-tdt-0.6b-v3-onnx
# Execution provider: cuda (deploy) | cpu (M1 dev) | coreml
# 'cuda' triggers the fail-loud GPU check at startup (invariant #2).
PARASCRIBE_EXECUTION_PROVIDER=cpu
PARASCRIBE_GPU_DEVICE_ID=0

# --- Server ---
PARASCRIBE_HOST=127.0.0.1
PARASCRIBE_PORT=8000

# --- Auth (bearer token; constant-time compare) ---
# Set one of these. If neither is set, the server starts but logs a loud warning.
PARASCRIBE_API_KEY=
# PARASCRIBE_API_KEY_FILE=/run/secrets/parascribe_api_key

# --- Chunking / VAD (mapped to onnx-asr VadOptions) ---
PARASCRIBE_MAX_CHUNK_S=24
PARASCRIBE_CHUNK_OVERLAP_S=0
PARASCRIBE_VAD_THRESHOLD=0.5

# --- Limits / IO ---
PARASCRIBE_WORK_DIR=/run/parascribe
PARASCRIBE_MAX_UPLOAD_MB=2048
# Max admitted requests (1 in-flight + queued); beyond this returns 503.
PARASCRIBE_MAX_QUEUE=16
PARASCRIBE_ENABLE_VIDEO=false

# --- Diarization (Phase 1; opt-in per request; needs requirements-diarization.txt) ---
PARASCRIBE_ENABLE_DIARIZATION=false
PARASCRIBE_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# cuda | cpu; blank = follow EXECUTION_PROVIDER. On an 11GB card shared with ASR,
# cpu avoids VRAM contention.
# PARASCRIBE_DIARIZATION_DEVICE=
# HF token for the one-time gated-model download (runs offline from cache after):
# PARASCRIBE_HF_TOKEN=
# PARASCRIBE_HF_TOKEN_FILE=/run/secrets/hf_token

# --- Language / logging ---
# Accepted for OpenAI compatibility but IGNORED by Parakeet TDT (it auto-detects);
# only Whisper/Canary backends would use it.
# PARASCRIBE_DEFAULT_LANGUAGE=
# Operational verbosity (content-free): DEBUG | INFO | WARNING | ERROR.
PARASCRIBE_LOG_LEVEL=INFO
# WARNING: debug_logging forces DEBUG and exposes transcript text in logs. Off by default.
PARASCRIBE_DEBUG_LOGGING=false
